class Solution {
    public int[] solution(String[] wallpaper) {
        int[] answer = {50,50,0,0};
        int cnt = 0;

        
        for(int i = 0 ; i < wallpaper.length ; i++){
            for(int j = 0 ; j < wallpaper[i].length() ; j++){
                if(wallpaper[i].charAt(j) == '#' && answer[0] > i){
                    answer[0] = i;
                }
                if(wallpaper[i].charAt(j) == '#' && answer[1] > j){
                    answer[1] = j;
                }
                if(wallpaper[i].charAt(j) == '#' && answer[2] < i){
                    answer[2] = i;
                }
                if(wallpaper[i].charAt(j) == '#' && answer[3] < j){
                    answer[3] = j;
                }
            }
        }
        
        answer[2]++;
        answer[3]++;
        
        return answer;
    }
}
